        keyLbl.BackgroundTransparency = 1
        keyLbl.Text              = key.Name
        keyLbl.TextColor3        = C.Accent
        keyLbl.Font              = Enum.Font.GothamBold
        keyLbl.TextSize          = 11
        keyLbl.Parent            = keyBox
 
        row.MouseEnter:Connect(function() tw(row, TW_FAST, {BackgroundColor3 = C.SurfaceHov}) end)
        row.MouseLeave:Connect(function() tw(row, TW_FAST, {BackgroundColor3 = C.Surface}) end)
        row.MouseButton1Click:Connect(function()
            binding = true
            keyLbl.Text       = "..."
            keyLbl.TextColor3 = C.TextMuted
            tw(keyBox, TW_FAST, {BackgroundColor3 = C.SurfaceAct})
        end)
 
        UIS.InputBegan:Connect(function(input, gpe)
            if binding and not gpe and input.UserInputType == Enum.UserInputType.Keyboard then
                binding           = false
                key               = input.KeyCode
                keyLbl.Text       = key.Name
                keyLbl.TextColor3 = C.Accent
                tw(keyBox, TW_FAST, {BackgroundColor3 = C.AccentOff})
            elseif not gpe and input.KeyCode == key and not binding then
                task.spawn(callback, key)
            end
        end)
 
        return {
            GetKey = function() return key end,
            SetKey = function(_, k) key = k; keyLbl.Text = k.Name end,
        }
    end
 
    -- ── TextInput ──────────────────────────────────────────────────────────
    function E:AddInput(text, placeholder, callback)
        local frame = Instance.new("Frame")
        frame.Size             = UDim2.new(1, -6, 0, 35)
        frame.BackgroundColor3 = C.Surface
        frame.BorderSizePixel  = 0
        frame.LayoutOrder      = nextOrder()
        frame.Parent           = Container
        corner(frame)
 
        local lbl = Instance.new("TextLabel")
        lbl.Size              = UDim2.new(0.38, 0, 1, 0)
        lbl.Position          = UDim2.new(0, 12, 0, 0)
        lbl.BackgroundTransparency = 1
        lbl.Text              = text
        lbl.TextColor3        = C.TextMuted
        lbl.Font              = Enum.Font.Gotham
        lbl.TextSize          = 12
        lbl.TextXAlignment    = Enum.TextXAlignment.Left
        lbl.Parent            = frame
 
        local boxBg = Instance.new("Frame")
        boxBg.Size             = UDim2.new(0.58, -8, 0, 22)
        boxBg.Position         = UDim2.new(0.4, 0, 0.5, -11)
        boxBg.BackgroundColor3 = C.AccentOff
        boxBg.BorderSizePixel  = 0
        boxBg.Parent           = frame
        corner(boxBg, 4)
 
        local box = Instance.new("TextBox")
        box.Size              = UDim2.new(1, -8, 1, 0)
        box.Position          = UDim2.new(0, 4, 0, 0)
        box.BackgroundTransparency = 1
        box.PlaceholderText   = placeholder or ""
        box.PlaceholderColor3 = C.TextMuted
        box.Text              = ""
        box.TextColor3        = C.TextSec
        box.Font              = Enum.Font.Gotham
        box.TextSize          = 12
        box.ClearTextOnFocus  = false
        box.Parent            = boxBg
 
        box.Focused:Connect(function()   tw(boxBg, TW_FAST, {BackgroundColor3 = C.SurfaceAct}) end)
        box.FocusLost:Connect(function(enter)
            tw(boxBg, TW_FAST, {BackgroundColor3 = C.AccentOff})
            if callback then task.spawn(callback, box.Text, enter) end
        end)
 
        return {
            GetText = function() return box.Text end,
            SetText = function(_, t) box.Text = t end,
        }
    end
 
    -- ── Separator ──────────────────────────────────────────────────────────
    function E:AddSeparator()
        local sep = Instance.new("Frame")
        sep.Size             = UDim2.new(1, -6, 0, 1)
        sep.BackgroundColor3 = Color3.fromRGB(45, 45, 55)
        sep.BorderSizePixel  = 0
        sep.LayoutOrder      = nextOrder()
        sep.Parent           = Container
    end
 
    -- ── Notification toast ─────────────────────────────────────────────────
    function E:Notify(text, duration)
        duration = duration or 3
 
        local toast = Instance.new("Frame")
        toast.Size             = UDim2.new(0, W - 40, 0, 30)
        toast.Position         = UDim2.new(0, 10, 0, -36)
        toast.BackgroundColor3 = C.Panel
        toast.BorderSizePixel  = 0
        toast.ZIndex           = 20
        toast.ClipsDescendants = true
        toast.Parent           = Main
        corner(toast, 5)
 
        local tLbl = Instance.new("TextLabel")
        tLbl.Size              = UDim2.new(1, -20, 1, 0)
        tLbl.Position          = UDim2.new(0, 8, 0, 0)
        tLbl.BackgroundTransparency = 1
        tLbl.Text              = text
        tLbl.TextColor3        = C.TextSec
        tLbl.Font              = Enum.Font.Gotham
        tLbl.TextSize          = 12
        tLbl.TextXAlignment    = Enum.TextXAlignment.Left
        tLbl.ZIndex            = 21
        tLbl.Parent            = toast
 
        local dot = Instance.new("Frame")
        dot.Size             = UDim2.new(0, 4, 0, 4)
        dot.Position         = UDim2.new(1, -10, 0.5, -2)
        dot.BackgroundColor3 = C.Accent
        dot.BorderSizePixel  = 0
        dot.ZIndex           = 21
        dot.Parent           = toast
        corner(dot, 2)
 
        tw(toast, TW_BACK, {Position = UDim2.new(0, 10, 0, 5)})
        task.delay(duration, function()
            tw(toast, TW_MED, {Position = UDim2.new(0, 10, 0, -36)})
            task.delay(0.25, function() toast:Destroy() end)
        end)
    end
 
    -- ── Window controls ────────────────────────────────────────────────────
    function E:SetTitle(t) Title.Text = t end
    function E:Show()  Main.Visible = true  end
    function E:Hide()  Main.Visible = false end
    function E:DestroyUI() SG:Destroy() end
 
    return E
end
 
return UILibrary
