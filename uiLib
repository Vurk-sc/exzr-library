    }, Enum.EasingStyle.Back)
 
    -- ════════════════════════════════════════════════════════════════
    --  Element API
    -- ════════════════════════════════════════════════════════════════
    local Window = {}
    local layoutOrder = 0
 
    local function nextOrder()
