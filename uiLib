            tween(stripe, 0.12, {Size = UDim2.new(0, 3, 0.6, 0), Position = UDim2.new(0, 0, 0.2, 0)})
            task.spawn(callback)
        end)
 
        return {
            SetText = function(_, t) lbl.Text = t end,
            SetEnabled = function(_, en)
                btn.Active = en
                tween(btn, 0.2, {BackgroundTransparency = en and 0 or 0.5})
                tween(lbl, 0.2, {TextTransparency = en and 0 or 0.5})
            end
        }
    end
 
    -- ── Toggle ──────────────────────────────────────────────────────
    function Window:AddToggle(text, default, callback)
        local state = default == true
 
        local row = Instance.new("TextButton")
        row.Size              = UDim2.new(1, 0, 0, 36)
        row.BackgroundColor3  = Theme.Surface
        row.AutoButtonColor   = false
        row.Text              = ""
        row.LayoutOrder       = nextOrder()
        row.Parent            = Container
        Instance.new("UICorner", row).CornerRadius = UDim.new(0, 6)
 
        local lbl = Instance.new("TextLabel")
        lbl.Size              = UDim2.new(1, -60, 1, 0)
        lbl.Position          = UDim2.new(0, 12, 0, 0)
        lbl.BackgroundTransparency = 1
        lbl.Text              = text
        lbl.TextColor3        = Theme.TextPrim
        lbl.Font              = Enum.Font.GothamSemibold
        lbl.TextSize          = 13
        lbl.TextXAlignment    = Enum.TextXAlignment.Left
        lbl.Parent            = row
 
        -- Pill track
        local track = Instance.new("Frame")
        track.Size            = UDim2.new(0, 38, 0, 20)
        track.Position        = UDim2.new(1, -50, 0.5, -10)
        track.BackgroundColor3 = state and Theme.Accent or Theme.AccentOff
        track.BorderSizePixel = 0
        track.Parent          = row
        Instance.new("UICorner", track).CornerRadius = UDim.new(1, 0)
 
        -- Knob
        local knob = Instance.new("Frame")
        knob.Size             = UDim2.new(0, 14, 0, 14)
        knob.Position         = state and UDim2.new(1, -17, 0.5, -7) or UDim2.new(0, 3, 0.5, -7)
        knob.BackgroundColor3 = Theme.White
        knob.BorderSizePixel  = 0
        knob.Parent           = track
        Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)
 
        local function refresh(animated)
            local t = animated and 0.2 or 0
            tween(track, t, {BackgroundColor3 = state and Theme.Accent or Theme.AccentOff})
            tween(knob, t, {
                Position = state and UDim2.new(1, -17, 0.5, -7) or UDim2.new(0, 3, 0.5, -7)
            }, Enum.EasingStyle.Back)
        end
 
        row.MouseEnter:Connect(function()
            tween(row, 0.15, {BackgroundColor3 = Theme.SurfaceHov})
        end)
        row.MouseLeave:Connect(function()
            tween(row, 0.15, {BackgroundColor3 = Theme.Surface})
        end)
        row.MouseButton1Click:Connect(function()
            state = not state
            refresh(true)
            task.spawn(callback, state)
        end)
 
        return {
            GetState  = function() return state end,
            SetState  = function(_, s, silent)
                state = s
                refresh(true)
                if not silent then task.spawn(callback, state) end
            end
        }
    end
 
    -- ── Slider ──────────────────────────────────────────────────────
    function Window:AddSlider(text, min, max, default, step, callback)
        -- Allow omitting step: AddSlider(text, min, max, default, callback)
        if type(step) == "function" then
            callback = step
            step     = 1
        end
        step     = step or 1
        callback = callback or function() end
        default  = math.clamp(default or min, min, max)
 
        local frame = Instance.new("Frame")
        frame.Size            = UDim2.new(1, 0, 0, 50)
        frame.BackgroundColor3 = Theme.Surface
        frame.BorderSizePixel = 0
        frame.LayoutOrder     = nextOrder()
        frame.Parent          = Container
        Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 6)
 
        local nameLbl = Instance.new("TextLabel")
        nameLbl.Size            = UDim2.new(0.65, 0, 0, 26)
        nameLbl.Position        = UDim2.new(0, 12, 0, 4)
        nameLbl.BackgroundTransparency = 1
        nameLbl.Text            = text
        nameLbl.TextColor3      = Theme.TextPrim
        nameLbl.Font            = Enum.Font.GothamSemibold
        nameLbl.TextSize        = 13
        nameLbl.TextXAlignment  = Enum.TextXAlignment.Left
        nameLbl.Parent          = frame
 
        local valLbl = Instance.new("TextLabel")
        valLbl.Size             = UDim2.new(0.3, -12, 0, 26)
        valLbl.Position         = UDim2.new(0.65, 0, 0, 4)
        valLbl.BackgroundTransparency = 1
        valLbl.Text             = tostring(default)
        valLbl.TextColor3       = Theme.Accent
        valLbl.Font             = Enum.Font.GothamBold
        valLbl.TextSize         = 13
        valLbl.TextXAlignment   = Enum.TextXAlignment.Right
        valLbl.Parent           = frame
 
        -- Track background
        local track = Instance.new("Frame")
        track.Size            = UDim2.new(1, -24, 0, 4)
        track.Position        = UDim2.new(0, 12, 0, 36)
        track.BackgroundColor3 = Theme.AccentOff
        track.BorderSizePixel = 0
        track.Parent          = frame
        Instance.new("UICorner", track).CornerRadius = UDim.new(1, 0)
 
        -- Filled portion
        local fill = Instance.new("Frame")
        local initPct = (default - min) / (max - min)
        fill.Size             = UDim2.new(initPct, 0, 1, 0)
        fill.BackgroundColor3 = Theme.Accent
        fill.BorderSizePixel  = 0
        fill.Parent           = track
        Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)
 
        -- Thumb knob (sits on the track, not inside it)
        local thumb = Instance.new("Frame")
        thumb.Size            = UDim2.new(0, 12, 0, 12)
        thumb.AnchorPoint     = Vector2.new(0.5, 0.5)
        thumb.Position        = UDim2.new(initPct, 0, 0.5, 0)
        thumb.BackgroundColor3 = Theme.White
        thumb.ZIndex          = 3
        thumb.Parent          = track
        Instance.new("UICorner", thumb).CornerRadius = UDim.new(1, 0)
 
        -- Invisible full-width drag button layered over track
        local hitbox = Instance.new("TextButton")
        hitbox.Size             = UDim2.new(1, 0, 0, 24)
        hitbox.Position         = UDim2.new(0, 0, 0.5, -12)
        hitbox.BackgroundTransparency = 1
        hitbox.Text             = ""
        hitbox.ZIndex           = 4
        hitbox.Parent           = track
 
        local currentValue = default
        local sliding = false
 
        local function setValue(pct)
            pct = math.clamp(pct, 0, 1)
            local raw  = min + pct * (max - min)
            local snap = math.round(raw / step) * step
            snap = math.clamp(snap, min, max)
            if snap == currentValue then return end
            currentValue = snap
            fill.Size  = UDim2.new(pct, 0, 1, 0)
            thumb.Position = UDim2.new(pct, 0, 0.5, 0)
            valLbl.Text = tostring(snap)
            task.spawn(callback, snap)
        end
 
        local function handleInput(input)
            local rel = (input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X
            setValue(rel)
        end
 
        hitbox.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1
            or input.UserInputType == Enum.UserInputType.Touch then
                sliding = true
                tween(thumb, 0.1, {Size = UDim2.new(0, 16, 0, 16)})
                handleInput(input)
            end
        end)
        hitbox.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1
            or input.UserInputType == Enum.UserInputType.Touch then
                sliding = false
                tween(thumb, 0.1, {Size = UDim2.new(0, 12, 0, 12)})
            end
        end)
        -- Global mouse move so dragging outside the hitbox still works
        UIS.InputChanged:Connect(function(input)
            if sliding and (
                input.UserInputType == Enum.UserInputType.MouseMovement or
                input.UserInputType == Enum.UserInputType.Touch
            ) then
                handleInput(input)
            end
        end)
        -- Release outside hitbox
        UIS.InputEnded:Connect(function(input)
            if sliding and (
                input.UserInputType == Enum.UserInputType.MouseButton1 or
                input.UserInputType == Enum.UserInputType.Touch
            ) then
                sliding = false
                tween(thumb, 0.1, {Size = UDim2.new(0, 12, 0, 12)})
            end
        end)
 
        return {
            GetValue  = function() return currentValue end,
            SetValue  = function(_, v, silent)
                local pct = (v - min) / (max - min)
                setValue(pct)
                if silent then
                    currentValue = v
                    valLbl.Text  = tostring(v)
                end
            end
        }
    end
 
    -- ── Dropdown ────────────────────────────────────────────────────
    function Window:AddDropdown(text, options, default, callback)
        local selected = default or options[1] or ""
        local open     = false
 
        local wrapper = Instance.new("Frame")
        wrapper.Size              = UDim2.new(1, 0, 0, 36)
        wrapper.BackgroundTransparency = 1
        wrapper.ClipsDescendants  = false
        wrapper.LayoutOrder       = nextOrder()
        wrapper.Parent            = Container
 
        local header = Instance.new("TextButton")
        header.Size              = UDim2.new(1, 0, 0, 36)
        header.BackgroundColor3  = Theme.Surface
        header.AutoButtonColor   = false
        header.Text              = ""
        header.ZIndex            = 5
        header.Parent            = wrapper
        Instance.new("UICorner", header).CornerRadius = UDim.new(0, 6)
 
        local labelName = Instance.new("TextLabel")
        labelName.Size            = UDim2.new(0.45, 0, 1, 0)
        labelName.Position        = UDim2.new(0, 12, 0, 0)
        labelName.BackgroundTransparency = 1
        labelName.Text            = text
        labelName.TextColor3      = Theme.TextSec
        labelName.Font            = Enum.Font.Gotham
        labelName.TextSize        = 12
        labelName.TextXAlignment  = Enum.TextXAlignment.Left
        labelName.ZIndex          = 5
        labelName.Parent          = header
 
        local labelVal = Instance.new("TextLabel")
        labelVal.Size             = UDim2.new(0.5, -30, 1, 0)
        labelVal.Position         = UDim2.new(0.45, 0, 0, 0)
        labelVal.BackgroundTransparency = 1
        labelVal.Text             = selected
        labelVal.TextColor3       = Theme.TextPrim
        labelVal.Font             = Enum.Font.GothamSemibold
        labelVal.TextSize         = 13
        labelVal.TextXAlignment   = Enum.TextXAlignment.Right
        labelVal.ZIndex           = 5
        labelVal.Parent           = header
 
        local arrow = Instance.new("TextLabel")
        arrow.Size                = UDim2.new(0, 20, 1, 0)
        arrow.Position            = UDim2.new(1, -24, 0, 0)
        arrow.BackgroundTransparency = 1
        arrow.Text                = "›"
        arrow.TextColor3          = Theme.Accent
        arrow.Font                = Enum.Font.GothamBold
        arrow.TextSize            = 16
        arrow.Rotation            = open and 90 or 0
        arrow.ZIndex              = 5
        arrow.Parent              = header
 
        -- Option list panel
        local panel = Instance.new("Frame")
        panel.Size              = UDim2.new(1, 0, 0, 0)
        panel.Position          = UDim2.new(0, 0, 1, 4)
        panel.BackgroundColor3  = Theme.Panel
        panel.ClipsDescendants  = true
        panel.BorderSizePixel   = 0
        panel.ZIndex            = 10
        panel.Visible           = false
        panel.Parent            = wrapper
        Instance.new("UICorner", panel).CornerRadius = UDim.new(0, 6)
 
        local pStroke = Instance.new("UIStroke")
        pStroke.Color = Theme.Separator
        pStroke.Thickness = 1
        pStroke.Parent = panel
 
        local pList = Instance.new("UIListLayout")
        pList.SortOrder = Enum.SortOrder.LayoutOrder
        pList.Parent = panel
 
        local optButtons = {}
        local OPTION_H   = 30
 
        for idx, opt in ipairs(options) do
            local obtn = Instance.new("TextButton")
            obtn.Size             = UDim2.new(1, 0, 0, OPTION_H)
            obtn.BackgroundColor3 = Theme.Panel
            obtn.AutoButtonColor  = false
            obtn.Text             = "  " .. tostring(opt)
            obtn.TextColor3       = opt == selected and Theme.Accent or Theme.TextPrim
            obtn.Font             = Enum.Font.GothamSemibold
            obtn.TextSize         = 12
            obtn.TextXAlignment   = Enum.TextXAlignment.Left
            obtn.LayoutOrder      = idx
            obtn.ZIndex           = 11
            obtn.Parent           = panel
            optButtons[opt]       = obtn
 
            obtn.MouseEnter:Connect(function()
                tween(obtn, 0.1, {BackgroundColor3 = Theme.Surface})
            end)
            obtn.MouseLeave:Connect(function()
                tween(obtn, 0.1, {BackgroundColor3 = Theme.Panel})
            end)
            obtn.MouseButton1Click:Connect(function()
                -- Deselect old
                if optButtons[selected] then
                    optButtons[selected].TextColor3 = Theme.TextPrim
                end
                selected = opt
                labelVal.Text = selected
                if optButtons[selected] then
                    optButtons[selected].TextColor3 = Theme.Accent
                end
                -- Close
                open = false
                tween(arrow, 0.2, {Rotation = 0})
                tween(panel, 0.2, {Size = UDim2.new(1, 0, 0, 0)})
                wrapper.Size = UDim2.new(1, 0, 0, 36)
                task.delay(0.2, function() panel.Visible = false end)
                task.spawn(callback, selected)
            end)
        end
 
        local totalH = #options * OPTION_H
 
        header.MouseButton1Click:Connect(function()
            open = not open
            tween(arrow, 0.2, {Rotation = open and 90 or 0})
            if open then
                panel.Visible = true
                wrapper.Size  = UDim2.new(1, 0, 0, 36 + totalH + 8)
                tween(panel, 0.2, {Size = UDim2.new(1, 0, 0, totalH)})
            else
                tween(panel, 0.2, {Size = UDim2.new(1, 0, 0, 0)})
                wrapper.Size = UDim2.new(1, 0, 0, 36)
                task.delay(0.2, function() panel.Visible = false end)
            end
            -- Refresh canvas height
            List:GetPropertyChangedSignal("AbsoluteContentSize"):Wait()
            Container.CanvasSize = UDim2.new(0, 0, 0, List.AbsoluteContentSize.Y + 16)
        end)
 
        header.MouseEnter:Connect(function()
            tween(header, 0.15, {BackgroundColor3 = Theme.SurfaceHov})
        end)
        header.MouseLeave:Connect(function()
            tween(header, 0.15, {BackgroundColor3 = Theme.Surface})
        end)
 
        return {
            GetSelected = function() return selected end,
            SetSelected = function(_, v, silent)
                if optButtons[selected] then optButtons[selected].TextColor3 = Theme.TextPrim end
                selected       = v
                labelVal.Text  = v
                if optButtons[v] then optButtons[v].TextColor3 = Theme.Accent end
                if not silent then task.spawn(callback, v) end
            end
        }
    end
 
    -- ── TextInput ───────────────────────────────────────────────────
    function Window:AddInput(text, placeholder, callback)
        local frame = Instance.new("Frame")
        frame.Size              = UDim2.new(1, 0, 0, 36)
        frame.BackgroundColor3  = Theme.Surface
        frame.BorderSizePixel   = 0
        frame.LayoutOrder       = nextOrder()
        frame.Parent            = Container
        Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 6)
 
        local lbl = Instance.new("TextLabel")
        lbl.Size              = UDim2.new(0.38, 0, 1, 0)
        lbl.Position          = UDim2.new(0, 12, 0, 0)
        lbl.BackgroundTransparency = 1
        lbl.Text              = text
        lbl.TextColor3        = Theme.TextSec
        lbl.Font              = Enum.Font.Gotham
        lbl.TextSize          = 12
        lbl.TextXAlignment    = Enum.TextXAlignment.Left
        lbl.Parent            = frame
 
        local box = Instance.new("TextBox")
        box.Size              = UDim2.new(0.58, -12, 0, 24)
        box.Position          = UDim2.new(0.4, 0, 0.5, -12)
        box.BackgroundColor3  = Theme.BG
        box.PlaceholderText   = placeholder or ""
        box.PlaceholderColor3 = Theme.TextMuted
        box.Text              = ""
        box.TextColor3        = Theme.TextPrim
        box.Font              = Enum.Font.Gotham
        box.TextSize          = 12
        box.ClearTextOnFocus  = false
        box.Parent            = frame
        Instance.new("UICorner", box).CornerRadius = UDim.new(0, 4)
 
        local boxStroke = Instance.new("UIStroke")
        boxStroke.Color       = Theme.Separator
        boxStroke.Thickness   = 1
        boxStroke.Parent      = box
 
        box.Focused:Connect(function()
            tween(boxStroke, 0.15, {Color = Theme.Accent})
        end)
        box.FocusLost:Connect(function(enterPressed)
            tween(boxStroke, 0.15, {Color = Theme.Separator})
            if callback then task.spawn(callback, box.Text, enterPressed) end
        end)
 
        return {
            GetText = function() return box.Text end,
            SetText = function(_, t) box.Text = t end,
        }
    end
 
    -- ── Separator ───────────────────────────────────────────────────
    function Window:AddSeparator()
        local sep = Instance.new("Frame")
        sep.Size              = UDim2.new(1, 0, 0, 1)
        sep.BackgroundColor3  = Theme.Separator
        sep.BorderSizePixel   = 0
        sep.LayoutOrder       = nextOrder()
        sep.Parent            = Container
    end
 
    -- ── Window-level controls ───────────────────────────────────────
    function Window:SetTitle(t)  TitleLbl.Text = t end
    function Window:Destroy()    SG:Destroy()       end
    function Window:Show()       SG.Enabled = true  end
    function Window:Hide()       SG.Enabled = false end
 
    return Window
end
 
return UILibrary
