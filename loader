local source = game:HttpGet("https://raw.githubusercontent.com/Vurk-sc/exzr-library/refs/heads/main/pfmain")

-- Simple execution that works on all executors
if not getgenv().executed then
    -- Try standard loadstring first
    local success, err = pcall(function()
        loadstring(source)()
    end)
    
    if not success then
        -- If that fails, try direct execution
        pcall(function()
            local func = loadstring(source)
            if func then func() end
        end)
    end
    
    getgenv().executed = true
end
