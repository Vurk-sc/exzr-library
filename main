-- ============================================================================
-- 1. PURE LUAU UI LIBRARY CORE FRAMEWORK (WITH COLOR PICKER & SLIDER)
-- ============================================================================
local UIS = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local CoreGui = game:GetService("CoreGui")
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")
local Camera = workspace.CurrentCamera

local UILibrary = {}

local function getSafeParent()
    if gethui then
        return gethui()
    elseif CoreGui:FindFirstChild("RobloxGui") then
        return CoreGui.RobloxGui
    end
    return CoreGui
end

local function makeDraggable(frame, dragHandle)
    local dragging, dragInput, dragStart, startPos

    local function update(input)
        local delta = input.Position - dragStart
        local targetPos = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        TweenService:Create(frame, TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Position = targetPos}):Play()
    end

    dragHandle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position

            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)

    dragHandle.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)

    UIS.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            update(input)
        end
    end)
end

function UILibrary.CreateWindow(titleText)
    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "VanguardUI_" .. math.random(1000, 9999)
    ScreenGui.ResetOnSpawn = false
    ScreenGui.Parent = getSafeParent()

    local MainFrame = Instance.new("Frame")
    MainFrame.Name = "MainFrame"
    MainFrame.Size = UDim2.new(0, 420, 0, 430)
    MainFrame.Position = UDim2.new(0.5, -210, 0.4, -215)
    MainFrame.BackgroundColor3 = Color3.fromRGB(24, 24, 28)
    MainFrame.BorderSizePixel = 0
    MainFrame.ClipsDescendants = false 
    MainFrame.Parent = ScreenGui

    local UICorner = Instance.new("UICorner")
    UICorner.CornerRadius = UDim.new(0, 8)
    UICorner.Parent = MainFrame

    local TopBar = Instance.new("Frame")
    TopBar.Name = "TopBar"
    TopBar.Size = UDim2.new(1, 0, 0, 40)
    TopBar.BackgroundColor3 = Color3.fromRGB(32, 32, 38)
    TopBar.BorderSizePixel = 0
    TopBar.Parent = MainFrame
    
    local TopCorner = Instance.new("UICorner")
    TopCorner.CornerRadius = UDim.new(0, 8)
    TopCorner.Parent = TopBar
    
    makeDraggable(MainFrame, TopBar)

    local Title = Instance.new("TextLabel")
    Title.Size = UDim2.new(1, -20, 1, 0)
    Title.Position = UDim2.new(0, 15, 0, 0)
    Title.BackgroundTransparency = 1
    Title.Text = titleText or "UI Window"
    Title.TextColor3 = Color3.fromRGB(240, 240, 245)
    Title.Font = Enum.Font.GothamBold
    Title.TextSize = 14
    Title.TextXAlignment = Enum.TextXAlignment.Left
    Title.Parent = TopBar

    local Container = Instance.new("ScrollingFrame")
    Container.Name = "Container"
    Container.Size = UDim2.new(1, -20, 1, -50)
    Container.Position = UDim2.new(0, 10, 0, 45)
    Container.BackgroundTransparency = 1
    Container.BorderSizePixel = 0
    Container.ScrollBarThickness = 4
    Container.ScrollBarImageColor3 = Color3.fromRGB(60, 60, 70)
    Container.ClipsDescendants = false
    Container.Parent = MainFrame

    local UIListLayout = Instance.new("UIListLayout")
    UIListLayout.Padding = UDim.new(0, 6)
    UIListLayout.SortOrder = Enum.SortOrder.LayoutOrder
    UIListLayout.Parent = Container

    UIListLayout.Changed:Connect(function()
        Container.CanvasSize = UDim2.new(0, 0, 0, UIListLayout.AbsoluteContentSize.Y + 10)
    end)

    local Elements = {}

    function Elements:AddLabel(text)
        local Label = Instance.new("TextLabel")
        Label.Size = UDim2.new(1, 0, 0, 25)
        Label.BackgroundTransparency = 1
        Label.Text = text
        Label.TextColor3 = Color3.fromRGB(160, 160, 170)
        Label.Font = Enum.Font.Gotham
        Label.TextSize = 13
        Label.TextXAlignment = Enum.TextXAlignment.Left
        Label.Parent = Container
    end

    function Elements:AddButton(text, callback)
        local Button = Instance.new("TextButton")
        Button.Size = UDim2.new(1, -6, 0, 35)
        Button.BackgroundColor3 = Color3.fromRGB(38, 38, 45)
        Button.AutoButtonColor = false
        Button.Text = "  " .. text
        Button.TextColor3 = Color3.fromRGB(230, 230, 235)
        Button.Font = Enum.Font.GothamSemibold
        Button.TextSize = 13
        Button.TextXAlignment = Enum.TextXAlignment.Left
        Button.Parent = Container

        local BCorner = Instance.new("UICorner")
        BCorner.CornerRadius = UDim.new(0, 5)
        BCorner.Parent = Button

        Button.MouseEnter:Connect(function()
            TweenService:Create(Button, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(48, 48, 58)}):Play()
        end)
        Button.MouseLeave:Connect(function()
            TweenService:Create(Button, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(38, 38, 45)}):Play()
        end)
        Button.MouseButton1Down:Connect(function()
            TweenService:Create(Button, TweenInfo.new(0.05), {BackgroundColor3 = Color3.fromRGB(58, 58, 70)}):Play()
            task.spawn(callback)
        end)
        Button.MouseButton1Up:Connect(function()
            TweenService:Create(Button, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(48, 48, 58)}):Play()
        end)
    end

    function Elements:AddToggle(text, defaultState, callback)
        local toggled = defaultState or false

        local ToggleFrame = Instance.new("TextButton")
        ToggleFrame.Size = UDim2.new(1, -6, 0, 35)
        ToggleFrame.BackgroundColor3 = Color3.fromRGB(38, 38, 45)
        ToggleFrame.AutoButtonColor = false
        ToggleFrame.Text = ""
        ToggleFrame.Parent = Container

        local TCorner = Instance.new("UICorner")
        TCorner.CornerRadius = UDim.new(0, 5)
        TCorner.Parent = ToggleFrame

        local ToggleLabel = Instance.new("TextLabel")
        ToggleLabel.Size = UDim2.new(1, -50, 1, 0)
        ToggleLabel.Position = UDim2.new(0, 12, 0, 0)
        ToggleLabel.BackgroundTransparency = 1
        ToggleLabel.Text = text
        ToggleLabel.TextColor3 = Color3.fromRGB(220, 220, 225)
        ToggleLabel.Font = Enum.Font.GothamSemibold
        ToggleLabel.TextSize = 13
        ToggleLabel.TextXAlignment = Enum.TextXAlignment.Left
        ToggleLabel.Parent = ToggleFrame

        local IndicatorBox = Instance.new("Frame")
        IndicatorBox.Size = UDim2.new(0, 36, 0, 18)
        IndicatorBox.Position = UDim2.new(1, -48, 0.5, -9)
        IndicatorBox.BackgroundColor3 = toggled and Color3.fromRGB(0, 180, 255) or Color3.fromRGB(24, 24, 28)
        IndicatorBox.Parent = ToggleFrame

        local ICorner = Instance.new("UICorner")
        ICorner.CornerRadius = UDim.new(1, 0)
        ICorner.Parent = IndicatorBox

        local SwitchNode = Instance.new("Frame")
        SwitchNode.Size = UDim2.new(0, 14, 0, 14)
        SwitchNode.Position = toggled and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7)
        SwitchNode.BackgroundColor3 = toggled and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(140, 140, 145)
        SwitchNode.Parent = IndicatorBox

        local SCorner = Instance.new("UICorner")
        SCorner.CornerRadius = UDim.new(1, 0)
        SCorner.Parent = SwitchNode

        local function updateToggle()
            local targetPos = toggled and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7)
            local targetColor = toggled and Color3.fromRGB(0, 180, 255) or Color3.fromRGB(24, 24, 28)
            local nodeColor = toggled and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(140, 140, 145)

            TweenService:Create(SwitchNode, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {Position = targetPos, BackgroundColor3 = nodeColor}):Play()
            TweenService:Create(IndicatorBox, TweenInfo.new(0.2), {BackgroundColor3 = targetColor}):Play()
        end

        ToggleFrame.MouseButton1Down:Connect(function()
            toggled = not toggled
            updateToggle()
            task.spawn(callback, toggled)
        end)
    end

    function Elements:AddSlider(text, min, max, default, callback)
        local SliderFrame = Instance.new("Frame")
        SliderFrame.Size = UDim2.new(1, -6, 0, 45)
        SliderFrame.BackgroundColor3 = Color3.fromRGB(38, 38, 45)
        SliderFrame.Parent = Container

        local SCorner = Instance.new("UICorner")
        SCorner.CornerRadius = UDim.new(0, 5)
        SCorner.Parent = SliderFrame

        local SliderLabel = Instance.new("TextLabel")
        SliderLabel.Size = UDim2.new(1, -100, 0, 25)
        SliderLabel.Position = UDim2.new(0, 12, 0, 2)
        SliderLabel.BackgroundTransparency = 1
        SliderLabel.Text = text
        SliderLabel.TextColor3 = Color3.fromRGB(220, 220, 225)
        SliderLabel.Font = Enum.Font.GothamSemibold
        SliderLabel.TextSize = 12
        SliderLabel.TextXAlignment = Enum.TextXAlignment.Left
        SliderLabel.Parent = SliderFrame

        local ValueLabel = Instance.new("TextLabel")
        ValueLabel.Size = UDim2.new(0, 80, 0, 25)
        ValueLabel.Position = UDim2.new(1, -92, 0, 2)
        ValueLabel.BackgroundTransparency = 1
        ValueLabel.Text = tostring(default)
        ValueLabel.TextColor3 = Color3.fromRGB(0, 180, 255)
        ValueLabel.Font = Enum.Font.GothamBold
        ValueLabel.TextSize = 12
        ValueLabel.TextXAlignment = Enum.TextXAlignment.Right
        ValueLabel.Parent = SliderFrame

        local SliderTrack = Instance.new("TextButton")
        SliderTrack.Size = UDim2.new(1, -24, 0, 4)
        SliderTrack.Position = UDim2.new(0, 12, 0, 32)
        SliderTrack.BackgroundColor3 = Color3.fromRGB(24, 24, 28)
        SliderTrack.Text = ""
        SliderTrack.AutoButtonColor = false
        SliderTrack.Parent = SliderFrame
        Instance.new("UICorner", SliderTrack).CornerRadius = UDim.new(1, 0)

        local SliderFill = Instance.new("Frame")
        SliderFill.Size = UDim2.new((default - min) / (max - min), 0, 1, 0)
        SliderFill.BackgroundColor3 = Color3.fromRGB(0, 180, 255)
        SliderFill.BorderSizePixel = 0
        SliderFill.Parent = SliderTrack
        Instance.new("UICorner", SliderFill).CornerRadius = UDim.new(1, 0)

        local Sliding = false

        local function updateValue(input)
            local percentage = math.clamp((input.Position.X - SliderTrack.AbsolutePosition.X) / SliderTrack.AbsoluteSize.X, 0, 1)
            local value = math.floor(min + (max - min) * percentage)
            SliderFill.Size = UDim2.new(percentage, 0, 1, 0)
            ValueLabel.Text = tostring(value)
            task.spawn(callback, value)
        end

        SliderTrack.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                Sliding = true
                updateValue(input)
            end
        end)

        UIS.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                Sliding = false
            end
        end)

        UIS.InputChanged:Connect(function(input)
            if Sliding and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                updateValue(input)
            end
        end)
    end

    function Elements:AddColorPicker(text, defaultColor, callback)
        local h, s, v = Color3.toHSV(defaultColor)
        local expanded = false

        local BaseFrame = Instance.new("Frame")
        BaseFrame.Size = UDim2.new(1, -6, 0, 35)
        BaseFrame.BackgroundColor3 = Color3.fromRGB(38, 38, 45)
        BaseFrame.ClipsDescendants = true
        BaseFrame.Parent = Container

        local BCorner = Instance.new("UICorner")
        BCorner.CornerRadius = UDim.new(0, 5)
        BCorner.Parent = BaseFrame

        local PickerLabel = Instance.new("TextLabel")
        PickerLabel.Size = UDim2.new(1, -60, 0, 35)
        PickerLabel.Position = UDim2.new(0, 12, 0, 0)
        PickerLabel.BackgroundTransparency = 1
        PickerLabel.Text = text
        PickerLabel.TextColor3 = Color3.fromRGB(220, 220, 225)
        PickerLabel.Font = Enum.Font.GothamSemibold
        PickerLabel.TextSize = 13
        PickerLabel.TextXAlignment = Enum.TextXAlignment.Left
        PickerLabel.Parent = BaseFrame

        local ColorDisplay = Instance.new("TextButton")
        ColorDisplay.Size = UDim2.new(0, 30, 0, 18)
        ColorDisplay.Position = UDim2.new(1, -42, 0, 8)
        ColorDisplay.BackgroundColor3 = defaultColor
        ColorDisplay.Text = ""
        ColorDisplay.Parent = BaseFrame

        local DCorner = Instance.new("UICorner")
        DCorner.CornerRadius = UDim.new(0, 4)
        DCorner.Parent = ColorDisplay

        local MenuTray = Instance.new("Frame")
        MenuTray.Position = UDim2.new(0, 12, 0, 40)
        MenuTray.Size = UDim2.new(1, -24, 0, 110)
        MenuTray.BackgroundTransparency = 1
        MenuTray.Parent = BaseFrame

        local SatValPad = Instance.new("TextButton")
        SatValPad.Size = UDim2.new(0, 140, 0, 100)
        SatValPad.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
        SatValPad.Text = ""
        SatValPad.AutoButtonColor = false
        SatValPad.Parent = MenuTray

        local GradientV = Instance.new("UIGradient")
        GradientV.Rotation = 90
        GradientV.Color = ColorSequence.new(Color3.fromRGB(255, 255, 255), Color3.fromRGB(0, 0, 0))
        GradientV.Parent = SatValPad

        local PadCursor = Instance.new("Frame")
        PadCursor.Size = UDim2.new(0, 6, 0, 6)
        PadCursor.AnchorPoint = Vector2.new(0.5, 0.5)
        PadCursor.Position = UDim2.new(s, 0, 1 - v, 0)
        PadCursor.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        PadCursor.Parent = SatValPad
        Instance.new("UICorner", PadCursor).CornerRadius = UDim.new(1, 0)

        local HueSlider = Instance.new("TextButton")
        HueSlider.Position = UDim2.new(0, 155, 0, 10)
        HueSlider.Size = UDim2.new(1, -155, 0, 12)
        HueSlider.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        HueSlider.Text = ""
        HueSlider.AutoButtonColor = false
        HueSlider.Parent = MenuTray

        local HueGradient = Instance.new("UIGradient")
        HueGradient.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 0, 0)),
            ColorSequenceKeypoint.new(0.167, Color3.fromRGB(255, 255, 0)),
            ColorSequenceKeypoint.new(0.333, Color3.fromRGB(0, 255, 0)),
            ColorSequenceKeypoint.new(0.5, Color3.fromRGB(0, 255, 255)),
            ColorSequenceKeypoint.new(0.667, Color3.fromRGB(0, 0, 255)),
            ColorSequenceKeypoint.new(0.833, Color3.fromRGB(255, 0, 255)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 0, 0))
        })
        HueGradient.Parent = HueSlider

        local HueCursor = Instance.new("Frame")
        HueCursor.Size = UDim2.new(0, 4, 1, 4)
        HueCursor.Position = UDim2.new(h, 0, 0, -2)
        HueCursor.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        HueCursor.Parent = HueSlider

        local function updateColor()
            local selectedColor = Color3.fromHSV(h, s, v)
            SatValPad.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
            ColorDisplay.BackgroundColor3 = selectedColor
            task.spawn(callback, selectedColor)
        end

        local checkingPad = false
        local checkingHue = false

        SatValPad.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                checkingPad = true
            end
        end)

        HueSlider.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                checkingHue = true
            end
        end)

        UIS.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                checkingPad = false
                checkingHue = false
            end
        end)

        UIS.InputChanged:Connect(function(input)
            if checkingPad and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                local absPos = SatValPad.AbsolutePosition
                local absSize = SatValPad.AbsoluteSize
                s = math.clamp((input.Position.X - absPos.X) / absSize.X, 0, 1)
                v = 1 - math.clamp((input.Position.Y - absPos.Y) / absSize.Y, 0, 1)
                PadCursor.Position = UDim2.new(s, 0, 1 - v, 0)
                updateColor()
            elseif checkingHue and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                local absPos = HueSlider.AbsolutePosition
                local absSize = HueSlider.AbsoluteSize
                h = math.clamp((input.Position.X - absPos.X) / absSize.X, 0, 1)
                HueCursor.Position = UDim2.new(h, 0, 0, -2)
                updateColor()
            end
        end)

        ColorDisplay.MouseButton1Click:Connect(function()
            expanded = not expanded
            local targetSize = expanded and UDim2.new(1, -6, 0, 160) or UDim2.new(1, -6, 0, 35)
            TweenService:Create(BaseFrame, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {Size = targetSize}):Play()
            
            task.wait(0.2)
            Container.CanvasSize = UDim2.new(0, 0, 0, UIListLayout.AbsoluteContentSize.Y + 10)
        end)
    end

    function Elements:DestroyUI()
        ScreenGui:Destroy()
    end

    UIS.InputBegan:Connect(function(input, processed)
        if not processed and input.KeyCode == Enum.KeyCode.LeftControl then
            MainFrame.Visible = not MainFrame.Visible
        end
    end)

    return Elements
end


-- ============================================================================
-- 2. PHANTOM FORCES ESP & ANTI-SHAKE CAMERA LOCK ENGINE
-- ============================================================================
local IsRunning = true
local BoxesEnabled = true
local TracersEnabled = true
local CameraLockEnabled = false 
local FovCircleEnabled = true 

local AccentColor = Color3.fromRGB(0, 180, 255)

local ActiveTracers = {}
local ActiveBoxes = {}
local EventConnections = {}
local EnemyModels = {}

-- Aim Settings
local LockStrength = 35       
local FovRadiusValue = 120    
local IsAimingIn = false      
local LockedTargetUID = nil 

-- Setup FOV Canvas Draw Element
local FOVCircle = Drawing.new("Circle")
FOVCircle.Thickness = 1.5
FOVCircle.NumSides = 64
FOVCircle.Radius = FovRadiusValue
FOVCircle.Filled = false
FOVCircle.Visible = FovCircleEnabled
FOVCircle.Color = AccentColor

local function create(className, properties)
    local instance = Instance.new(className)
    for k, v in pairs(properties) do
        instance[k] = v
    end
    return instance
end

local function applyGlobalColor()
    FOVCircle.Color = AccentColor
    for _, box in pairs(ActiveBoxes) do
        for _, part in ipairs(box:GetChildren()) do
            if part:IsA("Frame") then part.BackgroundColor3 = AccentColor end
        end
    end
    for _, data in pairs(ActiveTracers) do
        if data.TracerFrame then data.TracerFrame.BackgroundColor3 = AccentColor end
    end
end

local function createBox(uid)
    local box = create("BillboardGui", {
        Name = "Box_" .. uid,
        AlwaysOnTop = true,
        Size = UDim2.new(4.5, 0, 6.0, 0), 
        Active = false,
        ResetOnSpawn = false
    })
    
    create("Frame", {Size = UDim2.new(0, 1.5, 1, 0), Position = UDim2.new(0, 0, 0, 0), BackgroundColor3 = AccentColor, BorderSizePixel = 0, Parent = box})
    create("Frame", {Size = UDim2.new(0, 1.5, 1, 0), Position = UDim2.new(1, -1.5, 0, 0), BackgroundColor3 = AccentColor, BorderSizePixel = 0, Parent = box})
    create("Frame", {Size = UDim2.new(1, 0, 0, 1.5), Position = UDim2.new(0, 0, 0, 0), BackgroundColor3 = AccentColor, BorderSizePixel = 0, Parent = box})
    create("Frame", {Size = UDim2.new(1, 0, 0, 1.5), Position = UDim2.new(0, 0, 1, -1.5), BackgroundColor3 = AccentColor, BorderSizePixel = 0, Parent = box})
    
    return box
end

local function createTracer(uid)
    local screenGui = PlayerGui:FindFirstChild("Tracers") or create("ScreenGui", {
        Name = "Tracers", 
        IgnoreGuiInset = true, 
        ResetOnSpawn = false, 
        DisplayOrder = 999998,
        Parent = PlayerGui
    })
    return create("Frame", {
        Name = "Tracer_" .. uid,
        BackgroundColor3 = AccentColor,
        BorderSizePixel = 0,
        AnchorPoint = Vector2.new(0.5, 0.5),
        Visible = false,
        Parent = screenGui
    })
end

-- 1. Configuration Variable
local TargetBoneMode = "Torso" -- Can be "Torso" or "Head"

-- 2. Updated Registration Function
local function checkAndRegisterModel(model)
    if not model:IsA("Model") then return end
    
    -- Ensure we only target enemies based on your existing tag check
    local tag = model:FindFirstChild("PlayerTag", true)
    if tag and tag:IsA("TextLabel") and tag.TextColor3 == Color3.fromRGB(255, 10, 20) then
        
        -- Logic: If 'Head' is selected, look for Head first; otherwise prioritize Torso
        local targetPart = nil
        if TargetBoneMode == "Head" then
            targetPart = model:FindFirstChild("Head", true) or model:FindFirstChild("Torso", true)
        else
            targetPart = model:FindFirstChild("Torso", true) or model:FindFirstChild("Head", true)
        end
        
        if targetPart then
            EnemyModels[model:GetDebugId()] = {
                Model = model,
                Anchor = targetPart
            }
        end
    end
end

-- 3. UI Toggle Implementation
MyUI:AddToggle("Prioritize Head (Off=Torso)", false, function(state)
    TargetBoneMode = state and "Head" or "Torso"
    
    -- CRITICAL: Clear existing models to force an immediate re-scan
    -- This makes the switch instantaneous instead of waiting for a new respawn
    table.clear(EnemyModels) 
    
    print("Aimlock now targeting: " .. TargetBoneMode)
end)

local function updateVisuals()
    for _, box in pairs(ActiveBoxes) do
        box.Enabled = BoxesEnabled
    end
    for _, data in pairs(ActiveTracers) do
        if not TracersEnabled then data.TracerFrame.Visible = false end
    end
    FOVCircle.Visible = FovCircleEnabled
end

local function unloadSystem()
    IsRunning = false
    
    for _, connection in ipairs(EventConnections) do
        if connection then connection:Disconnect() end
    end
    
    local tracerGui = PlayerGui:FindFirstChild("Tracers")
    if tracerGui then tracerGui:Destroy() end
    
    if ActiveBoxes then
        for id, _ in pairs(ActiveBoxes) do
            if ActiveBoxes[id] then ActiveBoxes[id]:Destroy() end
        end
    end
    if ActiveTracers then
        for id, data in pairs(ActiveTracers) do
            if data.TracerFrame then data.TracerFrame:Destroy() end
        end
    end
    
    FOVCircle:Remove()
    
    ActiveBoxes = nil
    ActiveTracers = nil
    EnemyModels = nil
end

local function startESPSystem()
    local adsStart = UIS.InputBegan:Connect(function(input, processed)
        if not processed and input.UserInputType == Enum.UserInputType.MouseButton2 then
            IsAimingIn = true
        end
    end)
    local adsEnd = UIS.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton2 then
            IsAimingIn = false
            LockedTargetUID = nil 
        end
    end)
    table.insert(EventConnections, adsStart)
    table.insert(EventConnections, adsEnd)

    local addConnection = workspace.DescendantAdded:Connect(function(obj)
        if obj:IsA("Model") then
            task.wait(0.1)
            checkAndRegisterModel(obj)
        end
    end)
    table.insert(EventConnections, addConnection)

    local renderConnection = RunService.RenderStepped:Connect(function()
        if not IsRunning then return end
        
        for _, desc in ipairs(workspace:GetDescendants()) do
            checkAndRegisterModel(desc)
        end

        local screenSize = Camera.ViewportSize
        local startX = screenSize.X / 2
        local startY = screenSize.Y / 2

        FOVCircle.Position = Vector2.new(startX, startY)
        FOVCircle.Radius = FovRadiusValue

        local closestTargetVector = nil
        local shortestMouseDistance = math.huge
        local currentLockedTargetFound = false

        for id, data in pairs(EnemyModels) do
            local model = data.Model
            local anchor = data.Anchor
            
            if not model or not model.Parent or not anchor or not anchor.Parent or not model:IsDescendantOf(workspace) then
                EnemyModels[id] = nil
                if ActiveBoxes[id] then ActiveBoxes[id]:Destroy(); ActiveBoxes[id] = nil end
                if ActiveTracers[id] then ActiveTracers[id].TracerFrame:Destroy(); ActiveTracers[id] = nil end
                if LockedTargetUID == id then LockedTargetUID = nil end 
                continue
            end

            local screenPos, onScreen = Camera:WorldToViewportPoint(anchor.Position)
            
            if onScreen then
                local mouseDistance = (Vector2.new(screenPos.X, screenPos.Y) - Vector2.new(startX, startY)).Magnitude
                
                if CameraLockEnabled and IsAimingIn then
                    if LockedTargetUID ~= nil then
                        if id == LockedTargetUID then
                            currentLockedTargetFound = true
                            closestTargetVector = Vector2.new(screenPos.X, screenPos.Y)
                        end
                    else
                        if mouseDistance <= FovRadiusValue and mouseDistance < shortestMouseDistance then
                            shortestMouseDistance = mouseDistance
                            closestTargetVector = Vector2.new(screenPos.X, screenPos.Y)
                            LockedTargetUID = id 
                        end
                    end
                else
                    if mouseDistance <= FovRadiusValue and mouseDistance < shortestMouseDistance then
                        shortestMouseDistance = mouseDistance
                    end
                end
            end
            
            if BoxesEnabled then
                if not ActiveBoxes[id] then
                    local box = createBox(id)
                    box.Adornee = anchor
                    box.Parent = PlayerGui
                    ActiveBoxes[id] = box
                else
                    ActiveBoxes[id].Enabled = true
                    ActiveBoxes[id].Adornee = anchor
                end
            elseif ActiveBoxes[id] then
                ActiveBoxes[id].Enabled = false
            end
            
            if TracersEnabled and onScreen then
                if not ActiveTracers[id] then
                    local tracerFrame = createTracer(id)
                    ActiveTracers[id] = {TracerFrame = tracerFrame, RootPart = anchor}
                end
                
                local dx = screenPos.X - startX
                local dy = screenPos.Y - screenSize.Y 
                local distance = math.sqrt(dx*dx + dy*dy)

                local tf = ActiveTracers[id].TracerFrame
                tf.Size = UDim2.new(0, distance, 0, 1)
                tf.Position = UDim2.new(0, startX + (dx / 2), 0, screenSize.Y + (dy / 2))
                tf.Rotation = math.deg(math.atan2(dy, dx))
                tf.Visible = true
            elseif ActiveTracers[id] then
                ActiveTracers[id].TracerFrame.Visible = false
            end
        end

        if LockedTargetUID ~= nil and not currentLockedTargetFound then
            LockedTargetUID = nil
        end

        -- ANTI-SHAKE SMOOTHED MOUSE ALLOCATION
        if CameraLockEnabled and IsAimingIn and closestTargetVector and mousemoverel then
            -- Convert the Slider (1-100) into an exponential interpolation factor
            -- Lower slider values = extremely smooth tracking, High values = snappy tracking
            local smoothFactor = math.clamp((LockStrength / 100) * 0.25, 0.01, 1)
            
            local deltaX = (closestTargetVector.X - startX) * smoothFactor
            local deltaY = (closestTargetVector.Y - startY) * smoothFactor
            
            -- Filter out micro-movements under 0.5 pixels to completely kill crosshair shivering
            if math.abs(deltaX) > 0.5 or math.abs(deltaY) > 0.5 then
                mousemoverel(deltaX, deltaY)
            end
        end
    end)
    table.insert(EventConnections, renderConnection)
end


-- ============================================================================
-- 3. INTEGRATION SETUP (Linking Engine to Library Window)
-- ============================================================================

startESPSystem()

local MyUI = UILibrary.CreateWindow("Vanguard // Config Center")

MyUI:AddLabel("esp config")

MyUI:AddToggle("Enable 2d boxes", true, function(state)
    BoxesEnabled = state
    updateVisuals()
end)

MyUI:AddToggle("Enable Tracers", true, function(state)
    TracersEnabled = state
    updateVisuals()
end)

MyUI:AddToggle("Enable ADS Camera Lock", false, function(state)
    CameraLockEnabled = state
    updateVisuals()
end)

MyUI:AddToggle("Display FOV Radius Ring", true, function(state)
    FovCircleEnabled = state
    updateVisuals()
end)

MyUI:AddSlider("Aimlock Strength Modifier", 1, 100, 35, function(value)
    LockStrength = value
end)

MyUI:AddColorPicker("Global Highlight Color", Color3.fromRGB(0, 180, 255), function(newColor)
    AccentColor = newColor
    applyGlobalColor() 
end)

MyUI:AddLabel("made by stan1d")

MyUI:AddButton("Unload Engine & Hide UI", function()
    unloadSystem()
    MyUI:DestroyUI()
    print("[!] Vanguard Framework safely removed from environment memory.")
end)

MyUI:AddLabel("Tip: Press Left-CTRL to minimize/hide UI window.")
